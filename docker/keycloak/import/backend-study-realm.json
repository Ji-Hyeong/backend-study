{
  "realm": "backend-study",
  "enabled": true,
  "displayName": "Backend Study",
  "roles": {
    "realm": [
      { "name": "USER" },
      { "name": "ADMIN" }
    ]
  },
  "clients": [
    {
      "clientId": "backend-study-api",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:8084/*"],
      "webOrigins": ["http://localhost:8084"],
      "protocolMappers": [
        {
          "name": "study-user-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "study_user_id",
            "claim.name": "study_user_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "study-user",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "study-user", "temporary": false }],
      "realmRoles": ["USER"],
      "attributes": { "study_user_id": ["301"] }
    },
    {
      "username": "study-admin",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "study-admin", "temporary": false }],
      "realmRoles": ["ADMIN"],
      "attributes": { "study_user_id": ["302"] }
    }
  ]
}
